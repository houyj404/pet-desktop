{
  "productName": "pet-desktop",
  "version": "0.1.0",
  "identifier": "com.pet.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "桌面小宠物",
        "width": 140,
        "height": 180,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": true,
        "x": 1760,
        "y": 860
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
